# ------------------------------------------------------------
# Biomedical AI Infra Lab — Local Environment Example
# ------------------------------------------------------------
# Copy this file to .env for local development:
#
#   cp .env.example .env
#
# Never commit .env.
# ------------------------------------------------------------

# Application
APP_ENV=local
LOG_LEVEL=INFO

# External LLM
# Example providers: openai, anthropic, local_stub
EXTERNAL_LLM_PROVIDER=openai
EXTERNAL_LLM_MODEL=gpt-4.1-mini
EXTERNAL_LLM_API_KEY=replace_me

# NCBI / PubMed
# NCBI asks API users to include tool name and email.
NCBI_TOOL_NAME=governed-biomedical-graphrag
NCBI_EMAIL=your_email@example.com
NCBI_API_KEY=

# Local storage paths
VECTOR_STORE_PATH=builds/001-governed-biomedical-graphrag/data/vector_store
AUDIT_DB_PATH=builds/001-governed-biomedical-graphrag/data/audit/audit.duckdb
DAILYMED_CACHE_PATH=builds/001-governed-biomedical-graphrag/data/cached_sources/dailymed
PUBMED_CACHE_PATH=builds/001-governed-biomedical-graphrag/data/cached_sources/pubmed

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace_me

# Feature flags
ENABLE_PUBMED=true
ENABLE_GRAPH_VALIDATION=true
ENABLE_STRICT_SAFETY=true
ENABLE_AUDIT_LOGGING=true
